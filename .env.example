# Database Configuration
#DATABASE_URL=postgresql://username:password@localhost:5432/mcptools
DATABASE_URL=sqlite:///./mcptools.db

# Application Configuration
APP_NAME=mcptools.xin
APP_VERSION=0.1.0

# Environment (development, production, testing)
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration (for development, use *; for production, specify domains)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
